# Required: free key from https://finnhub.io
FINNHUB_API_KEY=

# Anthropic credentials: leave unset if you use `ant auth login` (SDK picks up the profile)
# ANTHROPIC_API_KEY=

# Optional: Telegram push notifications (create a bot via @BotFather, get your chat id via @userinfobot)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Brokerage: link Robinhood (read-only) with `bun run link:robinhood` — no env
# vars needed; tokens are stored locally in the SQLite settings table.

# Optional model overrides (defaults: claude-sonnet-5 deep / claude-haiku-4-5 fast)
# MARKETPULSE_MODEL_DEEP=
# MARKETPULSE_MODEL_FAST=

# Dashboard port
PORT=3000
